# Victrix — environment variables (copy to .env for local, set as Cloudflare
# secrets/vars in production). None are required while running the mock portal.

# Client-portal auth provider: 'mock' (default) | 'entra'
AUTH_PROVIDER=mock

# Client-portal data source: 'mock' (default) | 'dataverse'
PORTAL_DATA=mock

# Session-cookie signing key — REQUIRED once the portal is real.
# Production: set as a Cloudflare secret, never commit:  wrangler secret put PORTAL_SESSION_SECRET
PORTAL_SESSION_SECRET=

# --- Microsoft Entra External ID (only when AUTH_PROVIDER=entra) ---
# e.g. https://<tenant>.ciamlogin.com/<tenant>.onmicrosoft.com/v2.0
ENTRA_AUTHORITY=
ENTRA_CLIENT_ID=
# Confidential web client → keep secret out of the repo (Cloudflare secret)
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=

# --- Portal data backend (only when PORTAL_DATA=dataverse / a real API) ---
# e.g. https://<org>.crm3.dynamics.com/api/data/v9.2
DATAVERSE_API_URL=
