---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  /** Page title — appended with the site name. */
  title?: string;
  /** Meta description for SEO / social previews. */
  description?: string;
  /** Open Graph / Twitter share image (path under the site root). */
  image?: string;
  /** og:type — "article" for blog posts enables richer share cards. */
  ogType?: 'website' | 'article';
  /** For articles: ISO publish date → article:published_time. */
  publishedTime?: string;
  /** For articles: tags → article:tag. */
  tags?: string[];
}

const SITE_NAME = 'Victrix';
const DEFAULT_DESCRIPTION =
  'Victrix — services-conseils en TI et solutions de productivité pour les entreprises et les organisations publiques.';

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = '/og-image.png',
  ogType = 'website',
  publishedTime,
  tags,
} = Astro.props;

// Build the <title>: "Page — Victrix", or just the site name on the home page.
const fullTitle = title ? `${title} — ${SITE_NAME}` : SITE_NAME;

// Absolute URLs (from `site` in astro.config) for canonical + social tags.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    {/* Icons + theme */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#083957" />

    {/* Preload the primary fonts to cut layout shift on first paint */}
    <link rel="preload" href="/fonts/Montserrat-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Montserrat-Bold.woff2" as="font" type="font/woff2" crossorigin />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Victrix" />
    <meta property="og:locale" content="fr_CA" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === 'article' && tags?.map((t) => <meta property="article:tag" content={t} />)}

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {/* Hide the announcement bar before first paint if it was dismissed this
        session — prevents a flash/layout jump on every navigation. */}
    <script is:inline>
      try {
        if (sessionStorage.getItem('victrix-announce') === 'closed') {
          document.documentElement.classList.add('announce-dismissed');
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Aller au contenu principal</a>

    <!-- Global header (a page can override it by filling the "header" slot). -->
    <slot name="header"><Header /></slot>

    <main id="main-content">
      <slot />
    </main>

    <!-- Global footer (a page can override it by filling the "footer" slot). -->
    <slot name="footer"><Footer /></slot>
  </body>
</html>
