---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { type Locale, defaultLocale, otherLocale, htmlLang, swapLocale } from '../i18n/config';
import { useTranslations } from '../i18n/ui';

interface Props {
  /** Page locale. Required so chrome, <html lang>, and hreflang are correct. */
  lang?: Locale;
  /** Page title — appended with the site name. */
  title?: string;
  /** Meta description for SEO / social previews. */
  description?: string;
  /** Open Graph / Twitter share image (path under the site root). */
  image?: string;
  /** og:type — "article" for blog posts enables richer share cards. */
  ogType?: 'website' | 'article';
  /** For articles: ISO publish date → article:published_time. */
  publishedTime?: string;
  /** For articles: tags → article:tag. */
  tags?: string[];
  /**
   * Path of the equivalent page in the OTHER locale (for the language switch
   * and hreflang). Defaults to swapping the URL's locale prefix — pages with
   * non-mirrored paths (e.g. the portal) pass this explicitly.
   */
  altLocalePath?: string;
}

const {
  lang = defaultLocale,
  title,
  description,
  image = '/og-image.png',
  ogType = 'website',
  publishedTime,
  tags,
  altLocalePath,
} = Astro.props;

const t = useTranslations(lang);
const other = otherLocale[lang];

const SITE_NAME = t.siteName;
const fullTitle = title ? `${title} — ${SITE_NAME}` : SITE_NAME;
const metaDescription = description ?? t.defaultDescription;

// Canonical + per-locale alternates for hreflang and the language switch.
const altPath = altLocalePath ?? swapLocale(Astro.url.pathname, other);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const altURL = new URL(altPath, Astro.site);
const frURL = lang === 'fr' ? canonicalURL : altURL;
const enURL = lang === 'en' ? canonicalURL : altURL;
const ogImageURL = new URL(image, Astro.site);
const ogLocale = lang === 'fr' ? 'fr_CA' : 'en_CA';
const ogLocaleAlt = lang === 'fr' ? 'en_CA' : 'fr_CA';
---

<!doctype html>
<html lang={htmlLang[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    {/* Language alternates */}
    <link rel="alternate" hreflang="fr-CA" href={frURL} />
    <link rel="alternate" hreflang="en-CA" href={enURL} />
    <link rel="alternate" hreflang="x-default" href={frURL} />

    {/* Icons + theme — official Victrix favicon */}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#002c46" />

    {/* Preload the primary fonts to cut layout shift on first paint */}
    <link rel="preload" href="/fonts/Montserrat-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Montserrat-Bold.woff2" as="font" type="font/woff2" crossorigin />

    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Victrix" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === 'article' && tags?.map((tag) => <meta property="article:tag" content={tag} />)}

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageURL} />

    {/* Hide the announcement bar before first paint if it was dismissed this
        session — prevents a flash/layout jump on every navigation. */}
    <script is:inline>
      try {
        if (sessionStorage.getItem('victrix-announce') === 'closed') {
          document.documentElement.classList.add('announce-dismissed');
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{t.skipLink}</a>

    <!-- Global header (a page can override it by filling the "header" slot). -->
    <slot name="header"><Header lang={lang} altLocalePath={altPath} /></slot>

    <main id="main-content">
      <slot />
    </main>

    <!-- Global footer (a page can override it by filling the "footer" slot). -->
    <slot name="footer"><Footer lang={lang} /></slot>
  </body>
</html>
