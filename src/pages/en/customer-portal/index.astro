---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PortalLogin from '../../../components/PortalLogin.astro';
import { auth } from '../../../lib/auth';

/** Client-portal login entry (EN). On-demand so it can read the session/query. */
export const prerender = false;

const existing = await auth.getSession(Astro.request);
if (existing) return Astro.redirect('/mon-portail/tableau-de-bord');

const rawReturn = Astro.url.searchParams.get('returnTo');
const returnTo =
  rawReturn && rawReturn.startsWith('/') && !rawReturn.startsWith('//')
    ? rawReturn
    : '/mon-portail/tableau-de-bord';
const redirected = Astro.url.searchParams.has('returnTo');
const error = Astro.url.searchParams.has('error');
---

<BaseLayout
  lang="en"
  altLocalePath="/mon-portail"
  title="My portal"
  description="Sign in to your Victrix client portal to access your contracts, services and documents."
>
  <PortalLogin lang="en" returnTo={returnTo} redirected={redirected} error={error} />
</BaseLayout>
