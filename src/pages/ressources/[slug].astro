---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Format in UTC so a calendar date like 2026-05-28 isn't rolled back a day
// when rendered in a timezone behind UTC (e.g. America/Montreal).
const dateFmt = new Intl.DateTimeFormat('fr-CA', { dateStyle: 'long', timeZone: 'UTC' });
---

<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <article class="article">
    <div class="container article__inner">
      <header class="article__head">
        <a class="article__back" href="/ressources">← Toutes les ressources</a>

        {
          post.data.tags.length > 0 && (
            <ul role="list" class="article__tags">
              {post.data.tags.map((tag) => (
                <li class="tag">{tag}</li>
              ))}
            </ul>
          )
        }

        <h1>{post.data.title}</h1>

        <p class="article__meta">
          <time datetime={post.data.date.toISOString()}>
            {dateFmt.format(post.data.date)}
          </time>
        </p>
      </header>

      <Image
        class="article__cover"
        src={post.data.coverImage}
        alt=""
        widths={[600, 900, 1200]}
        sizes="(min-width: 800px) 760px, 100vw"
        loading="eager"
      />

      <div class="prose article__body">
        <Content />
      </div>

      <footer class="article__foot">
        <a class="btn btn--outline" href="/ressources">← Retour aux ressources</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    padding-block: var(--space-7) var(--space-9);
  }
  .article__inner {
    max-width: 800px;
  }
  .article__head {
    margin-bottom: var(--space-6);
  }
  .article__back {
    display: inline-block;
    margin-bottom: var(--space-5);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--fs-200);
    font-weight: var(--fw-medium);
  }
  .article__back:hover {
    color: var(--color-accent-blue);
  }
  .article__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0 0 var(--space-4);
  }
  .tag {
    font-size: var(--fs-100);
    font-weight: var(--fw-semibold);
    color: var(--color-navy);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 0.2em 0.7em;
  }
  .article__head h1 {
    max-width: 22ch;
  }
  .article__meta {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--fs-200);
  }
  .article__cover {
    width: 100%;
    height: auto;
    max-height: 440px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-7);
  }
  .article__foot {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }
</style>
