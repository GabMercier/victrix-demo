---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PortalLogin from '../../../components/PortalLogin.astro';
import { type Locale, isLocale, defaultLocale, otherLocale, localizePath } from '../../../i18n/config';
import { auth } from '../../../lib/auth';

/**
 * Client-portal login entry, localized: /fr/portail and /en/portail.
 * On-demand (reads the session/query at request time). Lives under the locale
 * prefix so the "prefix both" i18n routing serves it (non-prefixed pages 404).
 */
export const prerender = false;

const lang: Locale = isLocale(Astro.params.lang) ? Astro.params.lang : defaultLocale;

// Already signed in? Skip the login and go to the dashboard.
const existing = await auth.getSession(Astro.request);
if (existing) return Astro.redirect(localizePath('/portail/tableau-de-bord', lang));

const dashboard = localizePath('/portail/tableau-de-bord', lang);
const rawReturn = Astro.url.searchParams.get('returnTo');
const returnTo =
  rawReturn && rawReturn.startsWith('/') && !rawReturn.startsWith('//') ? rawReturn : dashboard;
const redirected = Astro.url.searchParams.has('returnTo');
const error = Astro.url.searchParams.has('error');

const title = lang === 'fr' ? 'Mon portail' : 'My portal';
const description =
  lang === 'fr'
    ? 'Connectez-vous à votre portail client Victrix pour accéder à vos contrats, services et documents.'
    : 'Sign in to your Victrix client portal to access your contracts, services and documents.';
---

<BaseLayout
  lang={lang}
  altLocalePath={localizePath('/portail', otherLocale[lang])}
  title={title}
  description={description}
>
  <PortalLogin lang={lang} returnTo={returnTo} redirected={redirected} error={error} />
</BaseLayout>
