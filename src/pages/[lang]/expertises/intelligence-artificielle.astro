---
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import aiHero from '../../../assets/ai-hero.png';
import { type Locale, localePaths, localizePath } from '../../../i18n/config';
import { aiContent } from '../../../i18n/content/ai';

export const getStaticPaths = localePaths;

const { lang } = Astro.props as { lang: Locale };
const ai = aiContent[lang];
const contactHref = localizePath('/contact', lang);
---

<BaseLayout lang={lang} title={ai.metaTitle} description={ai.metaDescription}>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <p class="hero__eyebrow">{ai.hero.eyebrow}</p>
        <h1 class="hero__title">
          <span class="hero__title-accent">{ai.hero.titleAccent}</span>
          {ai.hero.titleRest}
        </h1>
        <p class="hero__lead" set:html={ai.hero.lead}></p>
        <a class="btn hero__cta" href={contactHref}>{ai.hero.cta}</a>
      </div>
      <Image class="hero__img" src={aiHero} alt="" widths={[400, 760]} sizes="(min-width: 900px) 420px, 100vw" loading="eager" />
    </div>
  </section>

  <!-- From strategy to adoption -->
  <section class="section">
    <div class="container">
      <h2 class="block-title">{ai.fromStrategy.blockTitle}</h2>
      <div class="lead-card">
        <h3>{ai.fromStrategy.leadCardTitle}</h3>
        <p>{ai.fromStrategy.leadCardText}</p>
      </div>
      <ul role="list" class="num-grid num-grid--3">
        {
          ai.interventions.map((c) => (
            <li class="num-card">
              <p class="num-card__n" aria-hidden="true">{c.n}</p>
              <h3 class="num-card__title">{c.title}</h3>
              <p class="num-card__text">{c.text}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- How we work with your teams -->
  <section class="section section--tint">
    <div class="container">
      <h2 class="s-head">{ai.collaboration.sHead}</h2>
      <p class="s-intro" set:html={ai.collaboration.sIntro}></p>
      <ul role="list" class="num-grid num-grid--2">
        {
          ai.collaboration.items.map((c) => (
            <li class="num-card num-card--center">
              <p class="num-card__n" aria-hidden="true">{c.n}</p>
              <h3 class="num-card__title">{c.title}</h3>
              <p class="num-card__text">{c.text}</p>
              <a class="btn btn--primary" href={contactHref}>{c.cta}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- CTA box 1 -->
  <section class="section">
    <div class="container">
      <div class="cta-box">
        <h2>{ai.cta1.title}</h2>
        <p>{ai.cta1.text}</p>
        <a class="btn btn--primary" href={contactHref}>{ai.cta1.cta}</a>
      </div>
    </div>
  </section>

  <!-- Expertise areas -->
  <section class="section section--tint">
    <div class="container">
      <h2 class="s-head">{ai.areas.sHead}</h2>
      <p class="s-sub">{ai.areas.sSub}</p>
      <ul role="list" class="area-grid">
        {ai.areas.items.map((a) => <li class="area-box">{a}</li>)}
      </ul>
    </div>
  </section>

  <!-- Multi-technology -->
  <section class="section">
    <div class="container">
      <h2 class="s-head">{ai.multiTech.sHead}</h2>
      <div class="tech-grid">
        <div class="tech-col">
          <h3>{ai.multiTech.col1Title}</h3>
          <ul role="list">
            <li>OpenAI</li>
            <li>Llama</li>
            <li>Claude</li>
            <li>Gemini</li>
          </ul>
        </div>
        <div class="tech-col">
          <h3>{ai.multiTech.col2Title}</h3>
          <ul role="list">
            <li>Copilot 365</li>
            <li>Copilot (Dynamics 365)</li>
            <li>ChatGPT</li>
            <li>NowAssist (ServiceNow)</li>
          </ul>
        </div>
        <div class="tech-col">
          <h3>{ai.multiTech.col3Title}</h3>
          <ul role="list">
            <li>Copilot Studio</li>
            <li>Azure AI Foundry</li>
            <li>ServiceNow AI Platform</li>
            <li>
              {ai.multiTech.openLocalLabel}
              <ul role="list">
                <li>LangChain</li>
                <li>Hugging Face</li>
                <li>Docker</li>
                <li>Ollama</li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA box 2 -->
  <section class="section">
    <div class="container">
      <div class="cta-box">
        <h2>{ai.cta2.title}</h2>
        <a class="btn btn--primary" href={contactHref}>{ai.cta2.cta}</a>
      </div>
    </div>
  </section>

  <!-- Diverse pool of experts -->
  <section class="section section--tint">
    <div class="container">
      <h2 class="s-head">{ai.expertsPanel.sHead}</h2>
      <ul role="list" class="num-grid num-grid--2">
        {
          ai.expertsPanel.items.map((c) => (
            <li class="num-card num-card--center">
              <p class="num-card__n" aria-hidden="true">{c.n}</p>
              <h3 class="num-card__title">{c.title}</h3>
              <p class="num-card__text">{c.text}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Closing statement -->
  <section class="section">
    <div class="container closing">
      <h2 class="block-title">{ai.closing.blockTitle}</h2>
      <p set:html={ai.closing.p1}></p>
      <p set:html={ai.closing.p2}></p>
    </div>
  </section>

  <!-- Green CTA band -->
  <section class="green-cta">
    <div class="container green-cta__inner">
      <div>
        <h2>{ai.greenCta.title}</h2>
        <p>{ai.greenCta.text}</p>
      </div>
      <a class="btn btn--primary green-cta__btn" href={contactHref}>{ai.greenCta.cta}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .section {
    padding-block: var(--space-9);
  }
  .section--tint {
    background-color: var(--color-surface);
  }

  /* Centered section heading with green underline */
  .s-head {
    text-align: center;
    max-width: 24ch;
    margin-inline: auto;
    padding-bottom: var(--space-4);
    position: relative;
  }
  .s-head::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: 220px;
    max-width: 60%;
    height: 3px;
    background-color: var(--color-accent-green);
    border-radius: 2px;
  }
  .s-sub {
    text-align: center;
    color: var(--color-text-muted);
    margin: var(--space-4) auto 0;
  }
  .s-intro {
    max-width: 80ch;
    margin: var(--space-5) auto 0;
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--fs-400);
  }
  .block-title {
    text-align: center;
    max-width: 24ch;
    margin-inline: auto;
  }

  /* ---------- Hero ---------- */
  .hero {
    background:
      radial-gradient(120% 130% at 90% 10%, var(--color-navy-700) 0%, transparent 55%),
      linear-gradient(120deg, var(--color-navy-900) 0%, var(--color-navy) 70%);
    color: var(--color-text-invert);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: center;
    padding-block: var(--space-9);
  }
  @media (min-width: 900px) {
    .hero__inner {
      grid-template-columns: 1.1fr 0.9fr;
      gap: var(--space-8);
    }
  }
  .hero__eyebrow {
    color: var(--color-accent-green);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--fs-200);
    margin-bottom: var(--space-4);
  }
  .hero__title {
    color: var(--color-text-invert);
  }
  .hero__title-accent {
    color: var(--color-accent-green);
    display: block;
  }
  .hero__lead {
    margin-top: var(--space-5);
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--fs-400);
    max-width: 60ch;
  }
  .hero__lead strong {
    color: var(--color-text-invert);
  }
  .hero__cta {
    margin-top: var(--space-6);
    border: 2px solid rgba(255, 255, 255, 0.6);
    color: var(--color-text-invert);
  }
  .hero__cta:hover {
    background-color: var(--color-white);
    color: var(--color-navy);
  }
  .hero__img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  /* ---------- Lead card (overlapping) ---------- */
  .lead-card {
    max-width: 760px;
    margin: var(--space-6) auto var(--space-8);
    padding: var(--space-6);
    text-align: center;
    background-color: var(--color-bg);
    border-top: 3px solid var(--color-accent-green);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .lead-card h3 {
    color: var(--color-navy);
  }
  .lead-card p {
    margin: var(--space-3) auto 0;
    color: var(--color-text-muted);
    max-width: 65ch;
  }

  /* ---------- Numbered card grids ---------- */
  .num-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin: var(--space-7) 0 0;
  }
  @media (min-width: 720px) {
    .num-grid--3 {
      grid-template-columns: repeat(3, 1fr);
    }
    .num-grid--2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .num-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  .num-card--center {
    text-align: center;
    align-items: center;
  }
  .num-card__n {
    font-size: var(--fs-700);
    font-weight: var(--fw-extrabold);
    line-height: 1;
    color: var(--color-grey-200);
  }
  .num-card__title {
    color: var(--color-navy);
    font-size: var(--fs-500);
  }
  .num-card__text {
    color: var(--color-text-muted);
    flex-grow: 1;
  }
  .num-card--center .btn {
    margin-top: var(--space-2);
  }

  /* ---------- CTA box ---------- */
  .cta-box {
    text-align: center;
    max-width: 860px;
    margin-inline: auto;
    padding: var(--space-7);
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
  }
  .cta-box h2 {
    font-size: var(--fs-600);
  }
  .cta-box p {
    margin: var(--space-3) auto var(--space-5);
    color: var(--color-text-muted);
    max-width: 60ch;
  }
  .cta-box .btn {
    margin-top: var(--space-2);
  }

  /* ---------- Expertise area boxes ---------- */
  .area-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin: var(--space-7) 0 0;
  }
  @media (min-width: 700px) {
    .area-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .area-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .area-box {
    display: flex;
    align-items: center;
    min-height: 96px;
    padding: var(--space-5);
    text-align: center;
    justify-content: center;
    font-weight: var(--fw-semibold);
    color: var(--color-navy);
    background-color: var(--color-bg);
    border: 1.5px solid var(--color-accent-green);
    border-radius: var(--radius-md);
  }

  /* ---------- Multi-technology ---------- */
  .tech-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    margin-top: var(--space-7);
  }
  @media (min-width: 760px) {
    .tech-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .tech-col {
    padding: var(--space-6);
    border: 1.5px solid var(--color-accent-green);
    border-radius: var(--radius-md);
  }
  .tech-col h3 {
    text-align: center;
    color: var(--color-navy);
    font-size: var(--fs-500);
    margin-bottom: var(--space-4);
  }
  .tech-col ul {
    list-style: disc;
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .tech-col ul ul {
    margin-top: var(--space-2);
  }
  .tech-col li::marker {
    color: var(--color-accent-green);
  }

  /* ---------- Closing ---------- */
  .closing {
    max-width: 820px;
  }
  .closing p {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--fs-400);
    max-width: none;
  }
  .closing p strong {
    color: var(--color-navy);
  }

  /* ---------- Green CTA band ---------- */
  .green-cta {
    background-color: var(--color-accent-green);
    color: var(--color-navy);
  }
  .green-cta__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    padding-block: var(--space-8);
  }
  .green-cta h2 {
    color: var(--color-navy);
    max-width: 18ch;
  }
  .green-cta p {
    margin-top: var(--space-3);
    color: color-mix(in srgb, var(--color-navy) 85%, transparent);
    max-width: 60ch;
  }
  .green-cta__btn {
    font-weight: var(--fw-bold);
    flex-shrink: 0;
  }
</style>
