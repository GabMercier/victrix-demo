---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import aiHero from '../../assets/ai-hero.png';

// --- Repeated content, kept in arrays for clean templating ----------------
const interventions = [
  {
    n: '01',
    title: 'Exploration et analyse des opportunités',
    text: 'Repérez et priorisez les cas d’usage les plus prometteurs, puis élaborez une feuille de route claire pour lancer vos premières initiatives concrètes en IA.',
  },
  {
    n: '02',
    title: 'Développement d’agents et de solutions d’IA sur mesure',
    text: 'Concevez et déployez des solutions précises pour automatiser ou optimiser vos processus prioritaires, avec un accompagnement complet, du prototype au déploiement.',
  },
  {
    n: '03',
    title: 'Adoption sécurisée de l’IA générative',
    text: 'Structurez l’adoption de l’IA générative dans votre organisation grâce à un plan solide, du soutien aux utilisateurs et des formations ciblées, en mettant de l’avant les bonnes pratiques.',
  },
];

const collaboration = [
  {
    n: '01',
    title: 'Expertise continue',
    text: 'Nous mettons à votre disposition des experts en IA pour du conseil et du développement à long terme. Vous bénéficiez d’un accompagnement continu pour assurer le suivi, l’évolution et l’amélioration de vos projets.',
    cta: 'Je choisis un accompagnement continu',
  },
  {
    n: '02',
    title: 'Expertise sur mesure',
    text: 'Nous mobilisons nos experts pour vos projets spécifiques, en ajustant notre accompagnement selon vos priorités et vos échéances afin d’offrir une assistance ciblée qui garantit des résultats à la hauteur de vos attentes.',
    cta: 'J’ai un projet spécifique',
  },
];

const areas = [
  'Agents personnalisés et interconnectés pour des processus standardisés',
  'Personnalisation des grands modèles de langage (LLM) selon vos domaines ou vos données',
  'Consultation stratégique, gouvernance et feuille de route',
  'Gestion du changement et adoption de l’IA',
  'Sécurité et conformité des données',
];

const experts = [
  {
    n: '01',
    title: 'Consultation stratégique',
    text: 'Des conseillers d’expérience issus de notre équipe, de notre écosystème mondial et de nos partenaires spécialisés en IA.',
  },
  {
    n: '02',
    title: 'Architecture technologique et d’affaires',
    text: 'Des ingénieurs séniors reconnus comme experts en IA par nos clients.',
  },
  {
    n: '03',
    title: 'Expertise des solutions',
    text: 'Des spécialistes capables d’intervenir en cybersécurité, en ERP/CRM, en gestion des données et en moteurs de recherche intelligents.',
  },
  {
    n: '04',
    title: 'Analyse, développement et gestion du changement',
    text: 'Des experts qui vous accompagnent en analyse, en développement et en gestion du changement, forts d’une expérience concrète en projets d’IA et en preuves de concept.',
  },
];
---

<BaseLayout
  title="Intelligence artificielle"
  description="Services-conseils et d’intégration en intelligence artificielle adaptés à votre organisation : stratégie, agents sur mesure, adoption sécurisée de l’IA générative."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <p class="hero__eyebrow">Intelligence artificielle</p>
        <h1 class="hero__title">
          <span class="hero__title-accent">Services-conseils et d’intégration en IA</span>
          adaptés à votre organisation
        </h1>
        <p class="hero__lead">
          Adoptez l’intelligence artificielle de façon sécuritaire et responsable, avec une
          approche qui intègre les personnes, les processus et la gestion du changement à
          chaque étape. Profitez de l’accompagnement de nos conseillers pour sélectionner et
          adopter des solutions d’IA qui répondent à vos défis. Grâce à notre expertise
          multitechnologique, nous assurons une <strong>mise en œuvre et une adoption
          réussies</strong>, alignées sur vos objectifs d’affaires.
        </p>
        <a class="btn hero__cta" href="/contact">Parler à un expert en IA</a>
      </div>
      <Image class="hero__img" src={aiHero} alt="" widths={[400, 760]} sizes="(min-width: 900px) 420px, 100vw" loading="eager" />
    </div>
  </section>

  <!-- From strategy to adoption -->
  <section class="section">
    <div class="container">
      <h2 class="block-title">
        Mettez l’IA au service des entreprises et des organisations publiques
      </h2>
      <div class="lead-card">
        <h3>Avec Victrix, passez de la stratégie à l’adoption</h3>
        <p>
          Nos conseillers en intelligence artificielle peuvent intervenir à différentes
          étapes, selon votre niveau de maturité ou d’adoption de l’IA. Voici ce que couvrent
          nos interventions et services en IA.
        </p>
      </div>
      <ul role="list" class="num-grid num-grid--3">
        {
          interventions.map((c) => (
            <li class="num-card">
              <p class="num-card__n" aria-hidden="true">{c.n}</p>
              <h3 class="num-card__title">{c.title}</h3>
              <p class="num-card__text">{c.text}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- How we work with your teams -->
  <section class="section section--tint">
    <div class="container">
      <h2 class="s-head">
        Comment Victrix travaille avec vos équipes pour une adoption fluide et sécuritaire de l’IA
      </h2>
      <p class="s-intro">
        Que vous ayez un projet ciblé ou une initiative d’envergure, nous collaborons avec vos
        équipes pour <strong>évaluer les besoins</strong>, <strong>définir les objectifs</strong>
        et <strong>respecter vos échéances</strong>. Notre approche collaborative assure une
        adoption fluide et sécuritaire de l’IA, tout en maximisant la valeur pour votre
        organisation.
      </p>
      <ul role="list" class="num-grid num-grid--2">
        {
          collaboration.map((c) => (
            <li class="num-card num-card--center">
              <p class="num-card__n" aria-hidden="true">{c.n}</p>
              <h3 class="num-card__title">{c.title}</h3>
              <p class="num-card__text">{c.text}</p>
              <a class="btn btn--primary" href="/contact">{c.cta}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- CTA box 1 -->
  <section class="section">
    <div class="container">
      <div class="cta-box">
        <h2>Des questions sur un projet en intelligence artificielle&nbsp;?</h2>
        <p>Nos experts vous accompagnent à chaque étape pour assurer le succès de tous vos projets d’IA.</p>
        <a class="btn btn--primary" href="/contact">Consulter un spécialiste</a>
      </div>
    </div>
  </section>

  <!-- Expertise areas -->
  <section class="section section--tint">
    <div class="container">
      <h2 class="s-head">Expertise en intelligence artificielle</h2>
      <p class="s-sub">Nos domaines d’expertise en IA</p>
      <ul role="list" class="area-grid">
        {areas.map((a) => <li class="area-box">{a}</li>)}
      </ul>
    </div>
  </section>

  <!-- Multi-technology -->
  <section class="section">
    <div class="container">
      <h2 class="s-head">Expertise multitechnologique</h2>
      <div class="tech-grid">
        <div class="tech-col">
          <h3>Grands modèles de langage (LLM)</h3>
          <ul role="list">
            <li>OpenAI</li>
            <li>Llama</li>
            <li>Claude</li>
            <li>Gemini</li>
          </ul>
        </div>
        <div class="tech-col">
          <h3>Agents intégrés</h3>
          <ul role="list">
            <li>Copilot 365</li>
            <li>Copilot (Dynamics 365)</li>
            <li>ChatGPT</li>
            <li>NowAssist (ServiceNow)</li>
          </ul>
        </div>
        <div class="tech-col">
          <h3>Technologies et environnements de développement</h3>
          <ul role="list">
            <li>Copilot Studio</li>
            <li>Azure AI Foundry</li>
            <li>ServiceNow AI Platform</li>
            <li>
              Sources ouvertes et locales&nbsp;:
              <ul role="list">
                <li>LangChain</li>
                <li>Hugging Face</li>
                <li>Docker</li>
                <li>Ollama</li>
              </ul>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA box 2 -->
  <section class="section">
    <div class="container">
      <div class="cta-box">
        <h2>Prêt à démarrer votre projet d’intelligence artificielle&nbsp;?</h2>
        <a class="btn btn--primary" href="/contact">Consulter nos experts</a>
      </div>
    </div>
  </section>

  <!-- Diverse pool of experts -->
  <section class="section section--tint">
    <div class="container">
      <h2 class="s-head">
        Interventions structurées et ciblées, soutenues par un bassin diversifié d’experts en IA
      </h2>
      <ul role="list" class="num-grid num-grid--2">
        {
          experts.map((c) => (
            <li class="num-card num-card--center">
              <p class="num-card__n" aria-hidden="true">{c.n}</p>
              <h3 class="num-card__title">{c.title}</h3>
              <p class="num-card__text">{c.text}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Closing statement -->
  <section class="section">
    <div class="container closing">
      <h2 class="block-title">Victrix accélère l’adoption de l’IA dans votre organisation</h2>
      <p>
        Porté par un <strong>écosystème d’expertise</strong> qui englobe la technologie, la
        gouvernance des données, la cybersécurité et les services gérés, Victrix est votre
        partenaire stratégique pour la gestion de vos projets d’IA.
      </p>
      <p>
        Notre accompagnement en intelligence artificielle simplifie le déploiement, la stratégie
        et votre <strong>feuille de route en IA</strong>, peu importe votre niveau de maturité.
      </p>
    </div>
  </section>

  <!-- Green CTA band -->
  <section class="green-cta">
    <div class="container green-cta__inner">
      <div>
        <h2>Rencontrez nos conseillers en IA</h2>
        <p>
          Profitez de l’expertise de nos spécialistes en intelligence artificielle pour ajouter
          une réelle valeur à vos processus et accélérer l’atteinte de vos objectifs.
        </p>
      </div>
      <a class="btn btn--primary green-cta__btn" href="/contact">Adoptez l’IA avec Victrix</a>
    </div>
  </section>
</BaseLayout>

<style>
  .section {
    padding-block: var(--space-9);
  }
  .section--tint {
    background-color: var(--color-surface);
  }

  /* Centered section heading with green underline */
  .s-head {
    text-align: center;
    max-width: 24ch;
    margin-inline: auto;
    padding-bottom: var(--space-4);
    position: relative;
  }
  .s-head::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: 220px;
    max-width: 60%;
    height: 3px;
    background-color: var(--color-accent-green);
    border-radius: 2px;
  }
  .s-sub {
    text-align: center;
    color: var(--color-text-muted);
    margin: var(--space-4) auto 0;
  }
  .s-intro {
    max-width: 80ch;
    margin: var(--space-5) auto 0;
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--fs-400);
  }
  .block-title {
    text-align: center;
    max-width: 24ch;
    margin-inline: auto;
  }

  /* ---------- Hero ---------- */
  .hero {
    background:
      radial-gradient(120% 130% at 90% 10%, var(--color-navy-700) 0%, transparent 55%),
      linear-gradient(120deg, var(--color-navy-900) 0%, var(--color-navy) 70%);
    color: var(--color-text-invert);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: center;
    padding-block: var(--space-9);
  }
  @media (min-width: 900px) {
    .hero__inner {
      grid-template-columns: 1.1fr 0.9fr;
      gap: var(--space-8);
    }
  }
  .hero__eyebrow {
    color: var(--color-accent-green);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--fs-200);
    margin-bottom: var(--space-4);
  }
  .hero__title {
    color: var(--color-text-invert);
  }
  .hero__title-accent {
    color: var(--color-accent-green);
    display: block;
  }
  .hero__lead {
    margin-top: var(--space-5);
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--fs-400);
    max-width: 60ch;
  }
  .hero__lead strong {
    color: var(--color-text-invert);
  }
  .hero__cta {
    margin-top: var(--space-6);
    border: 2px solid rgba(255, 255, 255, 0.6);
    color: var(--color-text-invert);
  }
  .hero__cta:hover {
    background-color: var(--color-white);
    color: var(--color-navy);
  }
  .hero__img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  /* ---------- Lead card (overlapping) ---------- */
  .lead-card {
    max-width: 760px;
    margin: var(--space-6) auto var(--space-8);
    padding: var(--space-6);
    text-align: center;
    background-color: var(--color-bg);
    border-top: 3px solid var(--color-accent-green);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .lead-card h3 {
    color: var(--color-navy);
  }
  .lead-card p {
    margin: var(--space-3) auto 0;
    color: var(--color-text-muted);
    max-width: 65ch;
  }

  /* ---------- Numbered card grids ---------- */
  .num-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin: var(--space-7) 0 0;
  }
  @media (min-width: 720px) {
    .num-grid--3 {
      grid-template-columns: repeat(3, 1fr);
    }
    .num-grid--2 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .num-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  .num-card--center {
    text-align: center;
    align-items: center;
  }
  .num-card__n {
    font-size: var(--fs-700);
    font-weight: var(--fw-extrabold);
    line-height: 1;
    color: var(--color-grey-200);
  }
  .num-card__title {
    color: var(--color-navy);
    font-size: var(--fs-500);
  }
  .num-card__text {
    color: var(--color-text-muted);
    flex-grow: 1;
  }
  .num-card--center .btn {
    margin-top: var(--space-2);
  }

  /* ---------- CTA box ---------- */
  .cta-box {
    text-align: center;
    max-width: 860px;
    margin-inline: auto;
    padding: var(--space-7);
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
  }
  .cta-box h2 {
    font-size: var(--fs-600);
  }
  .cta-box p {
    margin: var(--space-3) auto var(--space-5);
    color: var(--color-text-muted);
    max-width: 60ch;
  }
  .cta-box .btn {
    margin-top: var(--space-2);
  }

  /* ---------- Expertise area boxes ---------- */
  .area-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin: var(--space-7) 0 0;
  }
  @media (min-width: 700px) {
    .area-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1000px) {
    .area-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .area-box {
    display: flex;
    align-items: center;
    min-height: 96px;
    padding: var(--space-5);
    text-align: center;
    justify-content: center;
    font-weight: var(--fw-semibold);
    color: var(--color-navy);
    background-color: var(--color-bg);
    border: 1.5px solid var(--color-accent-green);
    border-radius: var(--radius-md);
  }

  /* ---------- Multi-technology ---------- */
  .tech-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    margin-top: var(--space-7);
  }
  @media (min-width: 760px) {
    .tech-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .tech-col {
    padding: var(--space-6);
    border: 1.5px solid var(--color-accent-green);
    border-radius: var(--radius-md);
  }
  .tech-col h3 {
    text-align: center;
    color: var(--color-navy);
    font-size: var(--fs-500);
    margin-bottom: var(--space-4);
  }
  .tech-col ul {
    list-style: disc;
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .tech-col ul ul {
    margin-top: var(--space-2);
  }
  .tech-col li::marker {
    color: var(--color-accent-green);
  }

  /* ---------- Closing ---------- */
  .closing {
    max-width: 820px;
  }
  .closing p {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--fs-400);
    max-width: none;
  }
  .closing p strong {
    color: var(--color-navy);
  }

  /* ---------- Green CTA band ---------- */
  .green-cta {
    background-color: var(--color-accent-green);
    color: var(--color-navy);
  }
  .green-cta__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    padding-block: var(--space-8);
  }
  .green-cta h2 {
    color: var(--color-navy);
    max-width: 18ch;
  }
  .green-cta p {
    margin-top: var(--space-3);
    color: color-mix(in srgb, var(--color-navy) 85%, transparent);
    max-width: 60ch;
  }
  /* Colors/hover come from .btn--primary; only band-specific tweaks here. */
  .green-cta__btn {
    font-weight: var(--fw-bold);
    flex-shrink: 0;
  }
</style>
