---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ui } from '../i18n/ui';
import { localizePath } from '../i18n/config';

/**
 * Not-found page. A static site has a single 404.html that can be served for any
 * path, so the locale isn't known at build time: we render French (the default)
 * and a tiny client script swaps the copy + links to English when the requested
 * path is under /en/.
 */
const fr = ui.fr.notFound;
const en = ui.en.notFound;

const links = fr.links.map((l, i) => ({
  primary: l.primary,
  label: l.label,
  href: localizePath(l.href, 'fr'),
  enLabel: en.links[i].label,
  enHref: localizePath(en.links[i].href, 'en'),
}));

// EN strings handed to the client for the locale swap.
const enData = {
  title: en.title,
  eyebrow: en.eyebrow,
  text: en.text,
  requestedLabel: en.requestedLabel,
};
---

<BaseLayout lang="fr" title={fr.metaTitle} description={fr.metaDescription}>
  <section class="nf">
    <div class="container nf__inner">
      <span class="nf__badge" aria-hidden="true">
        <svg viewBox="0 0 48 48" width="44" height="44" role="img">
          <path
            fill="currentColor"
            d="M31.6 9.4a6 6 0 0 0-8.2-.2l-2.1 2 5.6 5.6 2-2.1a6 6 0 0 0 2.7-5.3ZM7.5 33.1a3 3 0 0 0 0 4.2l3.2 3.2a3 3 0 0 0 4.2 0L29.4 26 22 18.6 7.5 33.1Z"
          ></path>
          <path
            fill="currentColor"
            opacity="0.55"
            d="M40.5 14.5a8 8 0 0 1-9.4 1.4l-2 2 5.6 5.6 2-2a8 8 0 0 1 1.4-9.4l2.4 2.4Z"
          ></path>
        </svg>
      </span>

      <p class="nf__eyebrow" data-nf-eyebrow>{fr.eyebrow}</p>
      <h1 class="nf__title" data-nf-title>{fr.title}</h1>
      <p class="nf__text" data-nf-text>{fr.text}</p>

      <p class="nf__requested" data-requested hidden>
        <span data-nf-requested-label>{fr.requestedLabel}</span> <code data-requested-path></code>
      </p>

      <nav class="nf__actions" aria-label="Pages">
        {
          links.map((l) => (
            <a
              class={`btn ${l.primary ? 'btn--primary' : 'btn--outline'}`}
              href={l.href}
              data-nf-link
              data-en-href={l.enHref}
              data-en-label={l.enLabel}
            >
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ enData }}>
  const path = window.location.pathname;
  const isEn = path.startsWith('/en/') || path === '/en';

  // Switch the page copy + links to English when the requested path is /en/*.
  if (isEn) {
    document.documentElement.lang = 'en-CA';
    const set = (sel, text) => {
      const el = document.querySelector(sel);
      if (el) el.textContent = text;
    };
    set('[data-nf-eyebrow]', enData.eyebrow);
    set('[data-nf-title]', enData.title);
    set('[data-nf-text]', enData.text);
    set('[data-nf-requested-label]', enData.requestedLabel);
    document.title = enData.title + ' — Victrix';
    document.querySelectorAll('[data-nf-link]').forEach((a) => {
      const href = a.getAttribute('data-en-href');
      const label = a.getAttribute('data-en-label');
      if (href) a.setAttribute('href', href);
      if (label) a.textContent = label;
    });
  }

  // Show the address the visitor actually requested (helps it feel like a real site).
  const wrap = document.querySelector('[data-requested]');
  const slot = document.querySelector('[data-requested-path]');
  if (wrap && slot) {
    if (path && path !== '/404' && path !== '/404/') {
      slot.textContent = path;
      wrap.hidden = false;
    }
  }
</script>

<style>
  .nf {
    padding-block: var(--space-10);
  }
  .nf__inner {
    max-width: 620px;
    margin-inline: auto;
    text-align: center;
  }
  .nf__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 88px;
    height: 88px;
    border-radius: var(--radius-pill);
    background-color: var(--color-surface);
    color: var(--color-navy);
    margin-bottom: var(--space-5);
  }
  .nf__eyebrow {
    color: var(--color-accent);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--fs-200);
    margin-bottom: var(--space-2);
  }
  .nf__title {
    margin-bottom: var(--space-4);
  }
  .nf__text {
    margin: 0 auto;
    max-width: 52ch;
    color: var(--color-text-muted);
    font-size: var(--fs-400);
  }
  .nf__requested {
    margin: var(--space-5) auto 0;
    color: var(--color-text-muted);
    font-size: var(--fs-200);
  }
  .nf__requested code {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.5em;
    color: var(--color-navy);
  }
  .nf__requested[hidden] {
    display: none;
  }
  .nf__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-7);
  }
</style>
