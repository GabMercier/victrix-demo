---
import BaseLayout from '../layouts/BaseLayout.astro';

// Helpful destinations that already exist.
const links = [
  { label: 'Retour à l’accueil', href: '/', primary: true },
  { label: 'Consulter le blogue', href: '/ressources' },
  { label: 'Nous joindre', href: '/contact' },
];
---

<BaseLayout
  title="Page en construction"
  description="Cette section du site Victrix est en cours de construction. Découvrez les pages déjà en ligne."
>
  <section class="nf">
    <div class="container nf__inner">
      <span class="nf__badge" aria-hidden="true">
        <svg viewBox="0 0 48 48" width="44" height="44" role="img">
          <path
            fill="currentColor"
            d="M31.6 9.4a6 6 0 0 0-8.2-.2l-2.1 2 5.6 5.6 2-2.1a6 6 0 0 0 2.7-5.3ZM7.5 33.1a3 3 0 0 0 0 4.2l3.2 3.2a3 3 0 0 0 4.2 0L29.4 26 22 18.6 7.5 33.1Z"
          ></path>
          <path
            fill="currentColor"
            opacity="0.55"
            d="M40.5 14.5a8 8 0 0 1-9.4 1.4l-2 2 5.6 5.6 2-2a8 8 0 0 1 1.4-9.4l2.4 2.4Z"
          ></path>
        </svg>
      </span>

      <p class="nf__eyebrow">Erreur 404</p>
      <h1 class="nf__title">Page en construction</h1>
      <p class="nf__text">
        La page que vous cherchez n’est pas encore en ligne&nbsp;— ou n’existe pas.
        Ce site est un prototype&nbsp;: plusieurs sections sont toujours en cours de
        réalisation. Merci de votre patience&nbsp;!
      </p>

      <p class="nf__requested" data-requested hidden>
        Adresse demandée&nbsp;: <code data-requested-path></code>
      </p>

      <nav class="nf__actions" aria-label="Pages suggérées">
        {
          links.map((l) => (
            <a class={`btn ${l.primary ? 'btn--primary' : 'btn--outline'}`} href={l.href}>
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>
  </section>
</BaseLayout>

<script>
  // Show the address the visitor actually requested (helps it feel like a real site).
  const wrap = document.querySelector<HTMLElement>('[data-requested]');
  const slot = document.querySelector<HTMLElement>('[data-requested-path]');
  if (wrap && slot) {
    const path = window.location.pathname;
    if (path && path !== '/404' && path !== '/404/') {
      slot.textContent = path;
      wrap.hidden = false;
    }
  }
</script>

<style>
  .nf {
    padding-block: var(--space-10);
  }
  .nf__inner {
    max-width: 620px;
    margin-inline: auto;
    text-align: center;
  }
  .nf__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 88px;
    height: 88px;
    border-radius: var(--radius-pill);
    background-color: var(--color-surface);
    color: var(--color-navy);
    margin-bottom: var(--space-5);
  }
  .nf__eyebrow {
    color: var(--color-accent);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--fs-200);
    margin-bottom: var(--space-2);
  }
  .nf__title {
    margin-bottom: var(--space-4);
  }
  .nf__text {
    margin: 0 auto;
    max-width: 52ch;
    color: var(--color-text-muted);
    font-size: var(--fs-400);
  }
  .nf__requested {
    margin: var(--space-5) auto 0;
    color: var(--color-text-muted);
    font-size: var(--fs-200);
  }
  .nf__requested code {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.15em 0.5em;
    color: var(--color-navy);
  }
  .nf__requested[hidden] {
    display: none;
  }
  .nf__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-7);
  }
</style>
