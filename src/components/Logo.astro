---
import logoSvg from '../assets/victrix-logo.svg?raw';

interface Props {
  /**
   * 'dark'  → navy wordmark for light backgrounds (header).
   * 'light' → white wordmark for dark backgrounds (footer).
   * The SVG is the real Victrix logo extracted from the site; its two fills
   * (wordmark + "Powered by Alan Allman Associates" tagline) are recolored
   * here via the .lv-mark / .lv-tag classes.
   */
  variant?: 'light' | 'dark';
  class?: string;
}

const { variant = 'dark', class: className } = Astro.props;
---

<span class:list={['logo', `logo--${variant}`, className]} set:html={logoSvg} />

<style>
  .logo {
    display: inline-flex;
  }
  .logo :global(svg.logo-victrix) {
    display: block;
    height: var(--logo-height, 38px);
    width: auto;
  }

  /* Dark variant — light backgrounds (header). */
  .logo--dark :global(.lv-mark) {
    fill: var(--color-navy);
  }
  .logo--dark :global(.lv-tag) {
    fill: var(--color-grey-500);
  }

  /* Light variant — dark backgrounds (footer). */
  .logo--light :global(.lv-mark) {
    fill: var(--color-white);
  }
  .logo--light :global(.lv-tag) {
    fill: rgba(255, 255, 255, 0.7);
  }
</style>
