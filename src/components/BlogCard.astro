---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  post: CollectionEntry<'blog'>;
  /** Heading level for the card title, to keep document outline correct. */
  headingLevel?: 'h2' | 'h3';
}

const { post, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
// UTC so calendar dates don't roll back a day in timezones behind UTC.
const dateFmt = new Intl.DateTimeFormat('fr-CA', { dateStyle: 'long', timeZone: 'UTC' });
---

<article class="card">
  <a class="card__media" href={`/ressources/${post.id}`} tabindex="-1" aria-hidden="true">
    <Image
      src={post.data.coverImage}
      alt=""
      widths={[400, 800]}
      sizes="(min-width: 768px) 360px, 100vw"
      class="card__img"
    />
  </a>
  <div class="card__body">
    {
      post.data.tags.length > 0 && (
        <ul role="list" class="card__tags">
          {post.data.tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )
    }
    <Heading class="card__title">
      <a href={`/ressources/${post.id}`}>{post.data.title}</a>
    </Heading>
    <p class="card__date">
      <time datetime={post.data.date.toISOString()}>{dateFmt.format(post.data.date)}</time>
    </p>
    <p class="card__excerpt">{post.data.excerpt}</p>
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }
  .card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .card__media {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background-color: var(--color-surface);
  }
  .card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
  }
  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0;
  }
  .tag {
    font-size: var(--fs-100);
    font-weight: var(--fw-semibold);
    color: var(--color-navy);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    padding: 0.2em 0.7em;
  }
  .card__title {
    font-size: var(--fs-500);
    line-height: var(--lh-snug);
  }
  .card__title a {
    color: var(--color-navy);
    text-decoration: none;
  }
  /* Stretched link — whole card clickable, single accessible link. */
  .card__title a::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  .card:hover .card__title a {
    color: var(--color-accent-blue);
  }
  .card__date {
    margin: 0;
    font-size: var(--fs-200);
    color: var(--color-text-muted);
  }
  .card__excerpt {
    margin: 0;
    color: var(--color-text-muted);
  }
</style>
